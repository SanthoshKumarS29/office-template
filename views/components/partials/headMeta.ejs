<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<!-- Preconnect for best performance -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- Inter (400, 500, 600) + Montserrat (600, 700) -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

<% if (currentSection === "blogDetail") { %>
        <title><%= blog.title %></title>
        <meta name="description" content="<%= blog.description %>" />
        <meta property="og:title" content="Trending Hub - Latest Updates" />
        <meta property="og:description" content="Showcasing our latest projects and developments." />
        <meta property="og:image" content="https://example.com/images/banner.png" />
        <meta property="og:url" content="https://example.com/trending-hub" />
    <% } else { %>
        <title><%= seo.metaTitle || "AI Development Company" %></title>
        <meta name="description" content="<%= seo.metaDescription || '' %>" />
        <meta name="keywords" content="<%= seo.metaKeyword || '' %>" />
        <meta property="og:title" content="Trending Hub - Latest Updates" />
        <meta property="og:description" content="Showcasing our latest projects and developments." />
        <meta property="og:image" content="https://example.com/images/banner.png" />
        <meta property="og:url" content="https://example.com/trending-hub" />
<% } %>



