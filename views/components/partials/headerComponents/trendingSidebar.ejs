
<ul class="redirects">
    <% if (typeof nav !=='undefined' && nav.trendings && Array.isArray(nav.trendings)) { %>
        <% nav.trendings.forEach(link=> { %>
            <li class="<%= link.isdropDown ? 'withDropdown' : 'dropdown' %>">
                <a href="<%= link.path %>" rel="<%= link.rel %>">
                <%= link.title %>
                    <% if (link.isdropDown) { %>
                        <div>
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="arrow-transition-effect">
                                <g clip-path="url(#clip0_137_3)">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M16.06 10.94C16.3409 11.2213 16.4987 11.6025 16.4987 12C16.4987 12.3975 16.3409 12.7788 16.06 13.06L10.404 18.718C10.1226 18.9993 9.74102 19.1572 9.34316 19.1571C8.9453 19.157 8.56377 18.9989 8.28251 18.7175C8.00125 18.4361 7.84329 18.0545 7.84338 17.6566C7.84348 17.2588 8.00162 16.8773 8.28301 16.596L12.879 12L8.28301 7.404C8.00964 7.12123 7.85827 6.7424 7.8615 6.3491C7.86473 5.9558 8.0223 5.5795 8.30028 5.30126C8.57827 5.02302 8.95441 4.86508 9.34771 4.86148C9.741 4.85788 10.12 5.0089 10.403 5.282L16.061 10.939L16.06 10.94Z" fill="currentColor"/>
                                </g>
                                <defs>
                                <clipPath id="clip0_137_3">
                                <rect width="24" height="24" fill="currentColor"/>
                                </clipPath>
                                </defs>
                            </svg>
                        </div>
                    <% } %>
                </a>
            </li>
        <% }) %>
        <% } else { %>
        <li class="no-nav">
            <span>Navigation not available</span>
        </li>
    <% } %>
</ul>